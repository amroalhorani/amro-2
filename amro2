<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الطاولة الذكية</title>
    <style>
        :root {
            --primary-dark: #1a1a1a;
            --accent-color: #f39c12;
        }
        body {
            font-family: 'Cairo', sans-serif;
            background-color: #121212;
            color: white;
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }
        header {
            background-color: var(--primary-dark);
            text-align: center;
            padding: 15px;
            font-size: 1.8rem;
            border-bottom: 3px solid var(--accent-color);
        }
        .container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(3, 1fr);
            gap: 10px;
            padding: 10px;
            flex-grow: 1;
        }
        .btn {
            border: none;
            border-radius: 12px;
            font-size: 1.5rem;
            font-weight: bold;
            color: white;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }
        /* ألوان الأزرار */
        .menu { background: #e67e22; }
        .location { background: #3498db; }
        .video { background: #e74c3c; }
        .waiter { background: #2ecc71; }
        .bill { background: #f1c40f; color: #000; }
        .games { background: #9b59b6; }

        .btn:hover { opacity: 0.8; transform: scale(1.02); }

        /* نافذة المحتوى */
        #content-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 100;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .close-btn {
            position: absolute; top: 20px; right: 20px;
            background: red; color: white; border: none;
            padding: 10px 20px; border-radius: 5px; cursor: pointer;
        }
    </style>
</head>
<body>

<header>الطاولة الذكية</header>

<div class="container">
    <div class="btn menu" onclick="showContent('المنيو', 'هنا قائمة الطعام والمشروبات...')">المنيو</div>
    <div class="btn location" onclick="showContent('موقعنا', 'خريطة الوصول للمطعم...')">الموقع</div>
    <div class="btn video" onclick="showContent('الفيديو', 'شغل فيديوهات ترفيهية هنا...')">فيديو</div>
    <div class="btn waiter" onclick="showContent('نداء الويتر', 'جاري إرسال تنبيه للموظف...')">نداء الويتر</div>
    <div class="btn bill" onclick="showContent('الفاتورة', 'تفاصيل حسابك الحالي...')">الفاتورة</div>
    <div class="btn games" onclick="showContent('الألعاب', 'قائمة الألعاب المتاحة...')">الألعاب</div>
</div>

<div id="content-overlay">
    <button class="close-btn" onclick="closeContent()">إغلاق X</button>
    <h1 id="overlay-title"></h1>
    <div id="overlay-body" style="font-size: 1.2rem; text-align: center; padding: 20px;"></div>
</div>

<script>
    function showContent(title, body) {
        document.getElementById('overlay-title').innerText = title;
        document.getElementById('overlay-body').innerText = body;
        document.getElementById('content-overlay').style.display = 'flex';
    }
    function closeContent() {
        document.getElementById('content-overlay').style.display = 'none';
    }
</script>

</body>
</html>
